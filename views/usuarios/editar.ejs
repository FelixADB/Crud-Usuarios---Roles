<!DOCTYPE html>
<html lang="es">
<head>
    <title>Editar Usuario</title>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container d-flex justify-content-center">
        <div class="custom-card mt-2" style="max-width: 500px; width: 100%;">
            <h4 class="mb-4 fw-bold text-center">Actualizar Perfil</h4>
            
            <form action="/usuarios/editar/<%= usuario.id_usuario %>" method="POST" enctype="multipart/form-data">
                <div class="text-center mb-4">
                    <img src="<%= usuario.imagen %>" alt="Foto Actual" width="90" height="90" style="object-fit:cover; border-radius:50%; border: 2px solid var(--border-light); padding: 3px;">
                </div>

                <div class="mb-3">
                    <label class="form-label">Nombre Completo</label>
                    <input type="text" name="nombre" value="<%= usuario.nombre %>" required class="form-control">
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Correo Electrónico</label>
                    <input type="email" name="email" value="<%= usuario.email %>" required class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">Rol del Sistema</label>
                    <select name="id_rol" required class="form-select">
                        <% roles.forEach(rol => { %>
                            <option value="<%= rol.id_rol %>" <%= usuario.id_rol === rol.id_rol ? 'selected' : '' %> >
                                <%= rol.nombre %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <input type="hidden" name="imagen_actual" value="<%= usuario.imagen %>">
                
                <div class="mb-4">
                    <label class="form-label">Reemplazar foto (Opcional)</label>
                    <input type="file" name="imagen" accept="image/*" class="form-control">
                </div>
                
                <div class="d-flex gap-3 mt-4">
                    <a href="/usuarios" class="btn btn-warning flex-grow-1">Volver</a>
                    <button type="submit" class="btn btn-primary flex-grow-1">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>